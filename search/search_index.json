{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"]},"docs":[{"location":"","title":"Utterances that stir the soul.","text":""},{"location":"#_1","title":"\u300a\u846c\u9001\u7684\u8299\u8389\u83b2\u300b\u2308\u846c\u9001\u306e\u30d5\u30ea\u30fc\u30ec\u30f3\u230b","text":"<p>\u8299\u8389\u83b2\uff0c\u5176\u5b9e\u6211\u6700\u559c\u6b22\u7684\u9b54\u6cd5\u662f\u80fd\u7efd\u653e\u51fa\u7f8e\u4e3d\u82b1\u7530\u7684\u9b54\u6cd5\u3002 ------ \u4f0f\u62c9\u6885</p> <p>\u52aa\u529b\u8fc7\u7684\u4eba\u7686\u4e3a\u6218\u58eb\u3002 ------ \u827e\u6cfd</p> <p>\u9152\u4e3a\u767e\u836f\u4e4b\u957f(\u7b11)\u3002 ------ \u6d77\u5854 &amp;&amp; \u8d39\u4f26</p> <p>\u4ed6\u5df2\u7ecf\u5931\u53bb\u4e86\u7236\u6bcd\uff0c\u6211\u4e0d\u80fd\u518d\u593a\u8d70\u4ed6\u7684\u6545\u4e61\u3002 ------ \u8d5e\u56e0\u7684\u54e5\u54e5</p> <p>\u4ec5\u4ec5\u662f\u4e00\u573a\u5341\u5e74\u7684\u65c5\u884c\u554a\u3002 ------ \u8299\u8389\u83b2</p> <p>\u4e00\u822c\u60c5\u51b5\u4e0b\u53ef\u6ca1\u6709\u4eba\u4f1a\u62d2\u7edd\u201c\u968f\u4fbf\u9009\u4f60\u559c\u6b22\u7684\u5427\u201d\u8fd9\u53e5\u8bdd\u554a\u3002\u4e4b\u6240\u4ee5\u4f60\u62d2\u7edd\u4e86\u8fd9\u4e2a\u63d0\u8bae\u662f\u56e0\u4e3a\u8fd9\u53e5\u8bdd\u91cc\u5305\u542b\u7740\u91cd\u8981\u7684\u56de\u5fc6\u3002 ------ \u8d5e\u56e0</p> <p>\u5982\u679c\u4f60\u4e0d\u628a\u81ea\u5df1\u7684\u60f3\u6cd5\u8bf4\u51fa\u53e3\u7684\u8bdd\uff0c\u522b\u4eba\u662f\u4e0d\u4f1a\u660e\u767d\u7684\u3002 ------ \u8d5e\u56e0</p> <p>\u4e00\u4e2a\u4eba\u7684\u65f6\u5019\u7adf\u7136\u4f1a\u8fd9\u4e48\u5b89\u9759\u554a\u3002 ------ \u8d5e\u56e0</p> <p>\u6211\u53ea\u662f\u4e00\u76f4\uff0c\u4ee5\u7406\u60f3\u7684\u5927\u4eba\u4e3a\u76ee\u6807\uff0c\u88c5\u51fa\u4e00\u526f\u5927\u4eba\u8be5\u6709\u7684\u6837\u5b50\uff0c\u4e00\u6b65\u4e00\u6b65\u79ef\u7d2f\u81f3\u4eca\u800c\u5df2\u3002 ------\u6d77\u5854</p> <p>\u5c0f\u5b69\u5b50\u662f\u9700\u8981\u6709\u4e00\u4e2a\u80fd\u6210\u4e3a\u81ea\u5df1\u5fc3\u7075\u652f\u67f1\u7684\u5927\u4eba\u5728\u8eab\u8fb9\u7684\u3002 ------ \u6d77\u5854</p> <p>\u6211\u4e00\u76f4\u89c9\u5f97\u3001\u4e00\u4e2a\u4eba\u6240\u64c5\u957f\u7684\u9b54\u6cd5\u53d6\u51b3\u4e8e\u90a3\u4e2a\u4eba\u672c\u8eab\u7684\u6027\u683c\u548c\u7ecf\u5386\u3002 ------ \u5c24\u8d1d\u5c14</p> <p>\u6211\u4f1a\u72b9\u8c6b\u3001\u4e5f\u4f1a\u80c6\u602f\uff0c\u5c3d\u7ba1\u5982\u6b64\uff0c\u6211\u8fd8\u662f\u6740\u6b7b\u4e86\u6240\u6709\u6709\u5fc5\u8981\u6740\u7684\u4eba\u3002 ------ \u5a01\u4e9a\u8d1d\u9c81</p> <p>\u9b54\u6cd5\u5c31\u662f\u5728\u63a2\u6c42\u5b83\u7684\u65f6\u5019\u624d\u662f\u6700\u6709\u8da3\u7684\u54e6\u3002 ------ \u8299\u8389\u83b2</p> <p>\u9b54\u6cd5\u8fd9\u79cd\u4e1c\u897f\u5176\u63a2\u7d22\u7684\u8fc7\u7a0b\u624d\u662f\u6700\u6709\u8da3\u7684\u3002 ------ \u9093\u80af</p> <p>\u9b54\u6cd5\u8fd9\u79cd\u4e1c\u897f\u4e0d\u8fc7\u662f\u6740\u4eba\u7684\u5de5\u5177\u800c\u5df2\uff0c\u8fd8\u5206\u559c\u6b22\u4e0e\u5426\uff1f ------ \u5a01\u4e9a\u8d1d\u9c81</p> <p>\u5bf9\u6211\u800c\u8a00\uff0c\u9b54\u6cd5\u4e0d\u8fc7\u662f\u653f\u6cbb\u4e89\u6597\u7684\u9053\u5177\u7f62\u4e86\u3002 ------ \u9093\u80af</p> <p>\u56f0\u96be\u7684\u59d4\u6258\u4f1a\u8ba9\u4eba\u5174\u594b\u554a\u3002 ------ \u8f9b\u7f8e\u5c14</p> <p>\u5982\u679c\u662f\u52c7\u8005\u8f9b\u7f8e\u5c14\u7684\u8bdd\uff0c\u80af\u5b9a\u4e5f\u4f1a\u8fd9\u4e48\u505a\u7684\u3002 ------ \u8299\u8389\u83b2 &amp;&amp; \u83f2\u4f26 &amp;&amp; \u4fee\u5854\u5c14\u514b &amp;&amp; \u6d77\u5854 &amp;&amp; \u827e\u6cfd</p> <p>\u5e74\u8f7b\u4eba\u771f\u662f\u8840\u6c14\u65b9\u521a\u554a\u3002 ------ \u8299\u8389\u83b2 &amp;&amp; \u9093\u80af</p> <p></p>"},{"location":"under-construction/","title":"\u6b63\u5728\u5efa\u8bbe\u4e2d...","text":""},{"location":"Commend/","title":"Welcome to Commend\ud83d\udcab","text":"<p>\u6b22\u8fce\u6765\u5230 Ubuntu \u5b66\u4e60\u7b14\u8bb0\u7684\u4e16\u754c\uff0c\u8fd9\u662f\u4e00\u65b9\u4e13\u5c5e\u9886\u57df\uff0c\u8bb0\u5f55\u7740\u4ee3\u7801\u7684\u5f8b\u52a8\u548c\u6280\u672f\u7684\u5fc3\u4e8b\u3002</p> <p>\u6307\u4ee4\u7684\u821e\u8e48\uff0c\u4ee3\u7801\u7684\u65cb\u5f8b\uff0c\u6bcf\u4e00\u884c\u5b57\u7b26\u90fd\u662f\u4e00\u7bc7\u5b66\u4e60\u7684\u8bd7\u7ae0\u3002\u5728\u8fd9\u7247\u865a\u62df\u7684\u9886\u57df\u91cc\uff0c\u4e0e Ubuntu \u5171\u821e\uff0c\u5c06\u6280\u672f\u7684\u7e41\u661f\u70b9\u7f00\u6210\u4e00\u5e45\u5c5e\u4e8e\u5b66\u4e60\u8005\u7684\u661f\u7a7a\u753b\u5377\u3002</p> <p>\u6216\u8bb8\u4f60\u662f\u521d\u6d89 Linux \u7684\u5b66\u5b50\uff0c\u6216\u8bb8\u4f60\u662f\u4ee3\u7801\u4e16\u754c\u7684\u95ef\u5165\u8005\uff0c\u8fd9\u91cc\u5c06\u662f\u4f60\u5b66\u4e60\u7684\u6e2f\u6e7e\u3002\u4ee3\u7801\u662f\u601d\u8003\u7684\u8f7d\u4f53\uff0c\u6bcf\u4e00\u6b21\u5b66\u4e60\u90fd\u662f\u5fc3\u7075\u7684\u65c5\u7a0b\u3002\u5728\u8fd9\u91cc\uff0c\u8ba9\u6211\u4eec\u4e00\u540c\u9010\u5b57\u9010\u53e5\u5730\u4e66\u5199 Ubuntu \u5b66\u4e60\u7684\u6545\u4e8b\uff0c\u7528\u4ee3\u7801\u7684\u8bed\u8a00\u8c31\u5199\u6280\u672f\u7684\u8bd7\u7bc7\u3002</p> <p>\u6307\u4ee4\u5982\u8bd7\uff0c\u4ee3\u7801\u5982\u753b\uff0c\u613f <code>commend</code> \u5206\u533a\u6210\u4e3a\u4f60\u6280\u672f\u63a2\u7d22\u7684\u4e50\u56ed\u3002\u5728\u8fd9\u5b66\u65e0\u6b62\u5883\u7684\u65c5\u9014\u4e2d\uff0c\u8ba9\u6211\u4eec\u5171\u540c\u9886\u7565\u4ee3\u7801\u7684\u8bd7\u610f\uff0c\u53d1\u73b0 Ubuntu \u7684\u5947\u5999\u4e16\u754c\u3002</p> <p>\"\u547d\u4ee4\u884c\u4e0b\u7684\u8bd7\u7bc7\uff0c\u4ee3\u7801\u4e2d\u7684\u667a\u6167\uff0c\u613f\u5b66\u4e60\u4e4b\u8def\uff0c\u5982\u8bd7\u4e00\u822c\u7f8e\u5999\u3002\"</p>"},{"location":"Commend/cat/","title":"cat\u547d\u4ee4","text":""},{"location":"Commend/cat/#_1","title":"\u603b\u8ff0","text":"<pre><code>cat linux\u8def\u5f84\n</code></pre> <ul> <li><code>cat</code>\u67e5\u770b\u6587\u4ef6\u5185\u5bb9</li> </ul>"},{"location":"Commend/cat/#linux","title":"linux\u8def\u5f84","text":"<ul> <li>\u5fc5\u586b,\u8868\u793a\u8981\u67e5\u770b\u7684\u6587\u4ef6\u7684\u8def\u5f84,\u76f8\u5bf9\u8def\u5f84\u6216\u7edd\u5bf9\u8def\u5f84\u5747\u53ef</li> <li><code>cat ~/Desktop/Net/net.txt</code>\u67e5\u770b\u5728<code>/home/aimee/Desktop/Net</code>\u4e0b\u7684<code>net.txt</code>\u6587\u4ef6</li> <li><code>cat net.txt</code>\u67e5\u770b\u5728\u5f53\u524d\u76ee\u5f55\u7684<code>net.txt</code>\u6587\u4ef6</li> </ul>"},{"location":"Commend/cat/#_2","title":"\u62d3\u5c55","text":""},{"location":"Commend/cd/","title":"cd\u547d\u4ee4","text":""},{"location":"Commend/cd/#_1","title":"\u603b\u8ff0","text":"<pre><code>cd [linux\u8def\u5f84]\n</code></pre> <ul> <li><code>[linux\u8def\u5f84]</code>\u4e3a\u53ef\u9009\u53c2\u6570</li> </ul>"},{"location":"Commend/cd/#_2","title":"\u53c2\u6570","text":"<ul> <li>\u65e0</li> </ul>"},{"location":"Commend/cd/#_3","title":"\u9009\u9879","text":"<ul> <li><code>cd [linux\u8def\u5f84]</code>\u5207\u6362\u76ee\u5f55\u5230[linux\u8def\u5f84]</li> <li><code>cd</code>\u56de\u5230\u7528\u6237<code>home</code>\u76ee\u5f55<code>/home/aimee</code></li> <li><code>cd .</code>\u8868\u793a\u5f53\u524d\u76ee\u5f55 <code>cd ./Desktop</code>\u8868\u793a\u8fdb\u5165\u5f53\u524d\u76ee\u5f55\u4e0b\u7684Desktop\u76ee\u5f55</li> <li><code>cd ..</code>\u5207\u6362\u5230\u4e0a\u4e00\u7ea7 <code>cd ../..</code>\u5207\u6362\u5230\u4e0a\u4e8c\u7ea7</li> <li><code>cd ~</code>\u5207\u6362\u5230home\u76ee\u5f55\u4e0b\u7684\u5de5\u4f5c\u76ee\u5f55(/home/aimee)</li> <li><code>cd ~/Desktop</code>\u5373\u5207\u6362\u5230/home/aimee/Desktop</li> </ul>"},{"location":"Commend/cd/#_4","title":"\u62d3\u5c55","text":"<ul> <li>cd\u6765\u81ea\u82f1\u6587Change Directory</li> </ul>"},{"location":"Commend/ls/","title":"ls\u547d\u4ee4","text":""},{"location":"Commend/ls/#_1","title":"\u603b\u8ff0","text":"<pre><code>ls [ -a -l -h] [linux\u8def\u5f84]\n</code></pre> <ul> <li><code>[ -a -l -h] [linux\u8def\u5f84]</code>\u5747\u4e3a\u53ef\u9009\u53c2\u6570</li> <li>\u663e\u793a\u5f53\u524d\u4f4d\u7f6e\u6587\u4ef6\u5939\u5185\u7684\u6587\u4ef6\u548c\u6587\u4ef6\u5939</li> <li>\u9ed8\u8ba4\u52a0\u8f7d/home/aimee</li> </ul>"},{"location":"Commend/ls/#_2","title":"\u53c2\u6570","text":"<ul> <li><code>ls -a</code> \u8868\u793aall\uff0c\u5217\u51fa\u5168\u90e8\u6587\u4ef6(\u5305\u542b\u9690\u85cf\u6587\u4ef6\u548c\u6587\u4ef6\u5939)</li> <li><code>ls -l</code>\u8868\u793a\u4ee5\u7ad6\u5411\u5217\u8868\u7684\u5f62\u5f0f\u5c55\u793a\u5185\u5bb9\u548c\u5176\u4ed6\u4fe1\u606f</li> <li><code>ls -h</code>\u8868\u793a\u4ee5\u6613\u4e8e\u9605\u8bfb\u7684\u5f62\u5f0f\u5c55\u793a\u6587\u4ef6\u7684\u5927\u5c0f,\u8981\u4e0e<code>-l</code>\u4e00\u8d77\u4f7f\u7528</li> </ul>"},{"location":"Commend/ls/#_3","title":"\u9009\u9879","text":"<ul> <li> <p><code>ls /</code>\u5c55\u793a/(\u6839\u76ee\u5f55)\u4e0b\u7684\u5185\u5bb9</p> </li> <li> <p><code>ls [linux\u8def\u5f84]</code>\u5c55\u793a[linux\u8def\u5f84]\u4e0b\u7684\u5185\u5bb9</p> </li> </ul>"},{"location":"Commend/ls/#_4","title":"\u62d3\u5c55","text":"<ul> <li><code>ls -a -l</code> <code>la -la</code> <code>ls -al</code>\u90fd\u8868\u793a\u540c\u65f6\u4f7f\u7528<code>-l</code> <code>-a</code>\u7684\u529f\u80fd</li> <li><code>ls -al /</code>\u4ee5<code>-l</code> <code>-a</code>\u5c55\u793a/(\u6839\u76ee\u5f55)\u4e0b\u7684\u5185\u5bb9</li> <li><code>-a</code>\u662fall\uff0c<code>-l</code>\u662flong\uff0c<code>-h</code>\u662fhuman-readable(\u5f85\u5b9a\ud83d\ude22)</li> <li>\u4ee5<code>.</code>\u5f00\u5934\u7684\u6587\u4ef6\u6216\u6587\u4ef6\u5939\u9ed8\u8ba4\u88ab\u9690\u85cf,\u4f8b\u5982<code>.love.txt</code>\u5c31\u662f\u4e00\u4e2a\u9690\u85cf\u6587\u4ef6</li> <li>\u53ef\u4ee5\u7528<code>ls -lah</code>\u5077\u61d2(\ud83d\ude01)</li> </ul>"},{"location":"Commend/mkdir/","title":"mkdir\u547d\u4ee4","text":""},{"location":"Commend/mkdir/#_1","title":"\u603b\u8ff0","text":"<pre><code>mkdir [-p] linux\u8def\u5f84\n</code></pre> <ul> <li><code>mkdir</code>\u521b\u5efa\u76ee\u5f55</li> </ul>"},{"location":"Commend/mkdir/#-p","title":"[-p]","text":"<ul> <li>\u53ef\u9009,\u9002\u7528\u4e8e\u521b\u5efa\u8fde\u7eed\u591a\u5c42\u7ea7\u7684\u76ee\u5f55</li> <li><code>mkdir -p ~/god/cat</code>\u521b\u5efagod\u76ee\u5f55\u53ca\u5176\u4e0b\u7684cat\u76ee\u5f55</li> </ul>"},{"location":"Commend/mkdir/#linux","title":"linux\u8def\u5f84","text":"<ul> <li>\u5fc5\u586b,\u8868\u793a\u8981\u521b\u5efa\u7684\u6587\u4ef6\u5939\u7684\u8def\u5f84,\u76f8\u5bf9\u8def\u5f84\u6216\u7edd\u5bf9\u8def\u5f84\u5747\u53ef</li> </ul>"},{"location":"Commend/mkdir/#_2","title":"\u62d3\u5c55","text":"<ul> <li><code>mkdir</code>\u6765\u81eaMake Directory</li> <li><code>-p</code>\u597d\u50cf\u6765\u81ea<code>-parents</code></li> </ul>"},{"location":"Commend/more/","title":"more\u547d\u4ee4","text":""},{"location":"Commend/more/#_1","title":"\u603b\u8ff0","text":"<pre><code>more linux\u8def\u5f84\n</code></pre> <ul> <li><code>more</code>\u53ef\u4ee5\u5206\u9875\u67e5\u770b\u6587\u4ef6\u5185\u5bb9</li> </ul>"},{"location":"Commend/more/#linux","title":"linux\u8def\u5f84","text":"<ul> <li>\u5fc5\u586b,\u8868\u793a\u8981\u67e5\u770b\u7684\u6587\u4ef6\u7684\u8def\u5f84,\u76f8\u5bf9\u8def\u5f84\u6216\u7edd\u5bf9\u8def\u5f84\u5747\u53ef</li> <li><code>more ~/Desktop/Net/net.txt</code>\u67e5\u770b\u5728<code>/home/aimee/Desktop/Net</code>\u4e0b\u7684<code>net.txt</code>\u6587\u4ef6</li> <li><code>more net.txt</code>\u67e5\u770b\u5728\u5f53\u524d\u76ee\u5f55\u7684<code>net.txt</code>\u6587\u4ef6</li> </ul>"},{"location":"Commend/more/#_2","title":"\u62d3\u5c55","text":"<ul> <li>\u6309<code>q</code>\u952e\u9000\u51fa</li> <li>\u6309<code></code>(\u7a7a\u683c)\u952e\u5411\u540e\u7ffb\u9875</li> <li>\u6309<code>B</code>\u952e\u5411\u524d\u7ffb\u9875</li> </ul>"},{"location":"Commend/pwd/","title":"pwd\u547d\u4ee4","text":""},{"location":"Commend/pwd/#_1","title":"\u603b\u8ff0","text":"<pre><code>pwd\n</code></pre> <ul> <li><code>pwd</code>\u67e5\u770b\u5f53\u524d\u6240\u5728\u76ee\u5f55\u4f4d\u7f6e</li> </ul>"},{"location":"Commend/pwd/#_2","title":"\u53c2\u6570","text":"<ul> <li>\u65e0</li> </ul>"},{"location":"Commend/pwd/#_3","title":"\u9009\u9879","text":"<ul> <li>\u65e0</li> </ul>"},{"location":"Commend/pwd/#_4","title":"\u62d3\u5c55","text":"<ul> <li><code>pwd</code>\u6765\u81eaPrint Work Directory</li> </ul>"},{"location":"Commend/touch/","title":"touch\u547d\u4ee4","text":""},{"location":"Commend/touch/#_1","title":"\u603b\u8ff0","text":"<pre><code>touch linux\u8def\u5f84\n</code></pre> <ul> <li><code>touch</code>\u521b\u5efa\u6587\u4ef6</li> </ul>"},{"location":"Commend/touch/#linux","title":"linux\u8def\u5f84","text":"<ul> <li>\u5fc5\u586b,\u8868\u793a\u8981\u521b\u5efa\u7684\u6587\u4ef6\u7684\u8def\u5f84,\u76f8\u5bf9\u8def\u5f84\u6216\u7edd\u5bf9\u8def\u5f84\u5747\u53ef</li> <li><code>touch ~/Desktop/Net/net.txt</code>\u5728<code>/home/aimee/Desktop/Net</code>\u4e0b\u521b\u5efa<code>net.txt</code>\u6587\u4ef6</li> <li><code>touch net.txt</code>\u5728\u5f53\u524d\u76ee\u5f55\u521b\u5efa<code>net.txt</code>\u6587\u4ef6</li> </ul>"},{"location":"Commend/touch/#_2","title":"\u62d3\u5c55","text":""},{"location":"Note/fonts/","title":"Fonts","text":""},{"location":"Note/fonts/#mobile-fonts","title":"Mobile fonts","text":"<p>\u5976\u916a\u4f53</p> <p></p>"},{"location":"Note/stir/","title":"Utterances that stir the soul.","text":""},{"location":"Note/stir/#_1","title":"\u300a\u846c\u9001\u7684\u8299\u8389\u83b2\u300b\u2308\u846c\u9001\u306e\u30d5\u30ea\u30fc\u30ec\u30f3\u230b","text":"<p>\u8299\u8389\u83b2\uff0c\u5176\u5b9e\u6211\u6700\u559c\u6b22\u7684\u9b54\u6cd5\u662f\u80fd\u7efd\u653e\u51fa\u7f8e\u4e3d\u82b1\u7530\u7684\u9b54\u6cd5\u3002 ------ \u4f0f\u62c9\u6885</p> <p>\u52aa\u529b\u8fc7\u7684\u4eba\u7686\u4e3a\u6218\u58eb\u3002 ------ \u827e\u6cfd</p> <p>\u9152\u4e3a\u767e\u836f\u4e4b\u957f(\u7b11)\u3002 ------ \u6d77\u5854 &amp;&amp; \u8d39\u4f26</p> <p>\u4ed6\u5df2\u7ecf\u5931\u53bb\u4e86\u7236\u6bcd\uff0c\u6211\u4e0d\u80fd\u518d\u593a\u8d70\u4ed6\u7684\u6545\u4e61\u3002 ------ \u8d5e\u56e0\u7684\u54e5\u54e5</p> <p>\u4ec5\u4ec5\u662f\u4e00\u573a\u5341\u5e74\u7684\u65c5\u884c\u554a\u3002 ------ \u8299\u8389\u83b2</p> <p>\u4e00\u822c\u60c5\u51b5\u4e0b\u53ef\u6ca1\u6709\u4eba\u4f1a\u62d2\u7edd\u201c\u968f\u4fbf\u9009\u4f60\u559c\u6b22\u7684\u5427\u201d\u8fd9\u53e5\u8bdd\u554a\u3002\u4e4b\u6240\u4ee5\u4f60\u62d2\u7edd\u4e86\u8fd9\u4e2a\u63d0\u8bae\u662f\u56e0\u4e3a\u8fd9\u53e5\u8bdd\u91cc\u5305\u542b\u7740\u91cd\u8981\u7684\u56de\u5fc6\u3002 ------ \u8d5e\u56e0</p> <p>\u5982\u679c\u4f60\u4e0d\u628a\u81ea\u5df1\u7684\u60f3\u6cd5\u8bf4\u51fa\u53e3\u7684\u8bdd\uff0c\u522b\u4eba\u662f\u4e0d\u4f1a\u660e\u767d\u7684\u3002 ------ \u8d5e\u56e0</p> <p>\u4e00\u4e2a\u4eba\u7684\u65f6\u5019\u7adf\u7136\u4f1a\u8fd9\u4e48\u5b89\u9759\u554a\u3002 ------ \u8d5e\u56e0</p> <p>\u6211\u53ea\u662f\u4e00\u76f4\uff0c\u4ee5\u7406\u60f3\u7684\u5927\u4eba\u4e3a\u76ee\u6807\uff0c\u88c5\u51fa\u4e00\u526f\u5927\u4eba\u8be5\u6709\u7684\u6837\u5b50\uff0c\u4e00\u6b65\u4e00\u6b65\u79ef\u7d2f\u81f3\u4eca\u800c\u5df2\u3002 ------\u6d77\u5854</p> <p>\u5c0f\u5b69\u5b50\u662f\u9700\u8981\u6709\u4e00\u4e2a\u80fd\u6210\u4e3a\u81ea\u5df1\u5fc3\u7075\u652f\u67f1\u7684\u5927\u4eba\u5728\u8eab\u8fb9\u7684\u3002 ------ \u6d77\u5854</p> <p>\u6211\u4e00\u76f4\u89c9\u5f97\u3001\u4e00\u4e2a\u4eba\u6240\u64c5\u957f\u7684\u9b54\u6cd5\u53d6\u51b3\u4e8e\u90a3\u4e2a\u4eba\u672c\u8eab\u7684\u6027\u683c\u548c\u7ecf\u5386\u3002 ------ \u5c24\u8d1d\u5c14</p> <p>\u6211\u4f1a\u72b9\u8c6b\u3001\u4e5f\u4f1a\u80c6\u602f\uff0c\u5c3d\u7ba1\u5982\u6b64\uff0c\u6211\u8fd8\u662f\u6740\u6b7b\u4e86\u6240\u6709\u6709\u5fc5\u8981\u6740\u7684\u4eba\u3002 ------ \u5a01\u4e9a\u8d1d\u9c81</p> <p>\u9b54\u6cd5\u5c31\u662f\u5728\u63a2\u6c42\u5b83\u7684\u65f6\u5019\u624d\u662f\u6700\u6709\u8da3\u7684\u54e6\u3002 ------ \u8299\u8389\u83b2</p> <p>\u9b54\u6cd5\u8fd9\u79cd\u4e1c\u897f\u5176\u63a2\u7d22\u7684\u8fc7\u7a0b\u624d\u662f\u6700\u6709\u8da3\u7684\u3002 ------ \u9093\u80af</p> <p>\u9b54\u6cd5\u8fd9\u79cd\u4e1c\u897f\u4e0d\u8fc7\u662f\u6740\u4eba\u7684\u5de5\u5177\u800c\u5df2\uff0c\u8fd8\u5206\u559c\u6b22\u4e0e\u5426\uff1f ------ \u5a01\u4e9a\u8d1d\u9c81</p> <p>\u5bf9\u6211\u800c\u8a00\uff0c\u9b54\u6cd5\u4e0d\u8fc7\u662f\u653f\u6cbb\u4e89\u6597\u7684\u9053\u5177\u7f62\u4e86\u3002 ------ \u9093\u80af</p> <p>\u56f0\u96be\u7684\u59d4\u6258\u4f1a\u8ba9\u4eba\u5174\u594b\u554a\u3002 ------ \u8f9b\u7f8e\u5c14</p> <p>\u5982\u679c\u662f\u52c7\u8005\u8f9b\u7f8e\u5c14\u7684\u8bdd\uff0c\u80af\u5b9a\u4e5f\u4f1a\u8fd9\u4e48\u505a\u7684\u3002 ------ \u8299\u8389\u83b2 &amp;&amp; \u83f2\u4f26 &amp;&amp; \u4fee\u5854\u5c14\u514b &amp;&amp; \u6d77\u5854 &amp;&amp; \u827e\u6cfd</p> <p>\u5e74\u8f7b\u4eba\u771f\u662f\u8840\u6c14\u65b9\u521a\u554a\u3002 ------ \u8299\u8389\u83b2 &amp;&amp; \u9093\u80af</p> <p></p>"},{"location":"Ubuntu-Exploring/","title":"\u6b63\u5728\u5efa\u8bbe\u4e2d...","text":""},{"location":"Ubuntu-Exploring/#_2","title":"\ud83d\ude43\ud83d\ude43\ud83d\ude43\ud83d\ude43\ud83d\ude43","text":""},{"location":"Ubuntu-Exploring/#_3","title":"~\u61d2~\u61d2~\u61d2~","text":""},{"location":"Ubuntu-Exploring/#_4","title":"\ud83e\udee0\ud83e\udee0\ud83e\udee0\ud83e\udee0\ud83e\udee0","text":""},{"location":"Ubuntu-Exploring/clash/","title":"Clash(VPN)\u914d\u7f6e","text":"<p>**\u7531chatGPT-3.5\u751f\u6210,\u4e2a\u4eba\u7b14\u8bb0,\u672a\u5b9e\u8df5(\ud83d\ude34\ud83d\ude34\ud83d\ude34)</p>"},{"location":"Ubuntu-Exploring/clash/#clash","title":"\u5b89\u88c5Clash","text":"<p>\u9996\u5148\uff0c\u60a8\u9700\u8981\u5b89\u88c5Clash\u8f6f\u4ef6\u3002\u53ef\u4ee5\u4eceClash\u7684GitHub\u9875\u9762\u4e0b\u8f7d\u9002\u7528\u4e8eLinux\u7684\u4e8c\u8fdb\u5236\u6587\u4ef6\uff0c\u6216\u8005\u901a\u8fc7\u5305\u7ba1\u7406\u5668\u5b89\u88c5\u3002\u4ee5\u4e0b\u662f\u901a\u8fc7\u5305\u7ba1\u7406\u5668\u5b89\u88c5\u7684\u6b65\u9aa4\u3002</p>"},{"location":"Ubuntu-Exploring/clash/#clash_1","title":"\u4e0b\u8f7dClash\u4e8c\u8fdb\u5236\u6587\u4ef6","text":"<p>\u5728\u7ec8\u7aef\u4e2d\u6267\u884c\u4ee5\u4e0b\u547d\u4ee4\uff0c\u4e0b\u8f7dClash\u7684Linux\u4e8c\u8fdb\u5236\u6587\u4ef6\u3002</p> <pre><code>wget -O clash-linux-amd64.tar.gz https://github.com/Dreamacro/clash/releases/download/v1.7.0/clash-linux-amd64-v1.7.0.gz\n</code></pre>"},{"location":"Ubuntu-Exploring/clash/#_1","title":"\u89e3\u538b\u6587\u4ef6","text":"<p>\u89e3\u538b\u4e0b\u8f7d\u7684\u538b\u7f29\u5305\u3002</p> <pre><code>tar -xzvf clash-linux-amd64.tar.gz\n</code></pre>"},{"location":"Ubuntu-Exploring/clash/#clash_2","title":"\u5c06Clash\u4e8c\u8fdb\u5236\u6587\u4ef6\u79fb\u52a8\u5230\u5408\u9002\u7684\u4f4d\u7f6e","text":"<p>\u89e3\u538b\u540e\uff0c\u5c06Clash\u4e8c\u8fdb\u5236\u6587\u4ef6\u79fb\u52a8\u5230\u4e00\u4e2a\u9002\u5f53\u7684\u4f4d\u7f6e\uff0c\u4f8b\u5982 <code>/usr/local/bin</code>\u3002</p> <pre><code>sudo mv clash-linux-amd64 /usr/local/bin/clash\n</code></pre>"},{"location":"Ubuntu-Exploring/clash/#clash_3","title":"\u914d\u7f6eClash","text":"<p>\u521b\u5efa\u914d\u7f6e\u6587\u4ef6 <code>config.yaml</code>\uff0c\u5e76\u5c06\u5176\u653e\u7f6e\u5728\u5408\u9002\u7684\u4f4d\u7f6e\u3002\u60a8\u53ef\u4ee5\u4eceClash\u7684GitHub\u9875\u9762\u4e2d\u627e\u5230\u793a\u4f8b\u914d\u7f6e\u6587\u4ef6\uff0c\u5e76\u8fdb\u884c\u76f8\u5e94\u7684\u4fee\u6539\u4ee5\u7b26\u5408\u60a8\u7684\u9700\u6c42\u3002</p>"},{"location":"Ubuntu-Exploring/clash/#clash_4","title":"\u542f\u52a8Clash","text":"<p>\u4f7f\u7528\u7ec8\u7aef\u8fdb\u5165\u914d\u7f6e\u6587\u4ef6\u6240\u5728\u7684\u76ee\u5f55\uff0c\u5e76\u6267\u884c\u4ee5\u4e0b\u547d\u4ee4\u542f\u52a8Clash\u3002</p> <pre><code>clash -d /path/to/config/directory\n</code></pre> <p>\u8bf7\u5c06 <code>/path/to/config/directory</code> \u66ff\u6362\u4e3a\u60a8\u4fdd\u5b58 <code>config.yaml</code> \u6587\u4ef6\u7684\u76ee\u5f55\u8def\u5f84\u3002</p>"},{"location":"Ubuntu-Exploring/clash/#_2","title":"\u8bbe\u7f6e\u7cfb\u7edf\u4ee3\u7406","text":"<p>\u5728\u7cfb\u7edf\u8bbe\u7f6e\u4e2d\uff0c\u5c06\u4ee3\u7406\u8bbe\u7f6e\u4e3a <code>127.0.0.1:7890</code>\uff0c\u8fd9\u662fClash\u9ed8\u8ba4\u7684\u4ee3\u7406\u5730\u5740\u548c\u7aef\u53e3\u3002</p>"},{"location":"Ubuntu-Exploring/clash/#_3","title":"\u6d4b\u8bd5\u4ee3\u7406","text":"<p>\u6253\u5f00\u6d4f\u89c8\u5668\u6216\u5176\u4ed6\u7f51\u7edc\u5e94\u7528\u7a0b\u5e8f\uff0c\u5e76\u786e\u4fdd\u5b83\u4eec\u5df2\u7ecf\u5f00\u59cb\u901a\u8fc7Clash\u4ee3\u7406\u8fdb\u884c\u7f51\u7edc\u8fde\u63a5\u3002</p>"}]}